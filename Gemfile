source "https://rubygems.org"

# github-pages gem pins Jekyll + all approved plugins to exactly
# what GitHub Pages uses in production — no surprises on deploy.
gem "github-pages", group: :jekyll_plugins

# Windows/JRuby timezone fix (safe to leave in on all platforms)
gem "tzinfo-data", platforms: [:mingw, :x64_mingw, :mswin, :jruby]

# Faster file watching on Windows
gem "wdm", "~> 0.1", platforms: [:mingw, :x64_mingw, :mswin]
